/CDMS/Detector cute
/CDMS/CUTE/Stack snolab
/CDMS/UseShield
/control/execute {CDMS_SUPERSIM}/CDMSgeometry/macros/CUTE_T3_stack.mac

/CDMS/Source calib
/CDMS/CalibSource/AddIsotope 98 252

/CDMS/updateGeom

/CDMS/writeFilePrefix /scratch/user/perry5334/samples/DMC_SNOLAB_HV/DMCOutput/CUTE_Cf252calib_source
/CDMS/writeData false
/CDMS/writeTrees true

/run/autoSeed true
/run/numberOfThreads 20
/run/initialize
/run/setRunID 0
/run/setEventID 0
/run/beamOn 100